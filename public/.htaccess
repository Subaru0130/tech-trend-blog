
# ====================================
# Canonical URL Redirects (SEO Critical)
# ====================================
# All URLs must end up at: https://choiceguide.jp/path/
# This prevents duplicate content issues in Google.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # --------------------------------------------
    # STEP 1: Force HTTPS + non-www in ONE redirect
    # This avoids redirect chains (http://www → https://www → https://)
    # --------------------------------------------
    
    # If www OR http, redirect to https://choiceguide.jp
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^(.*)$ https://choiceguide.jp/$1 [R=301,L]
    
    # --------------------------------------------
    # STEP 2: Add trailing slash to directories
    # /categories/audio → /categories/audio/
    # But NOT for files like .html, .js, .css, etc.
    # --------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]{1,5}|/)$
    RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

# ====================================
# Old URL Redirects (Legacy support)
# ====================================
RedirectMatch 301 ^/rankings/best-wireless-earphones-under-10000/?$ /rankings/wireless-earphones/
RedirectMatch 301 ^/rankings/wireless-earphones-under-10000yen/?$ /rankings/wireless-earphones/

# ====================================
# Error Pages
# ====================================
ErrorDocument 404 /404.html
