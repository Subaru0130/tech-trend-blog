<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /link/
    
    # If the request is not a file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite everything else to index.php?id=...
    RewriteRule ^(.*)$ index.php?id=$1 [L,QSA]
</IfModule>